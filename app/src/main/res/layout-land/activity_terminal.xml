<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FF1A1A2E">

    <ScrollView
        android:id="@+id/terminal_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/terminal_shortcuts"
        app:layout_constraintWidth_percent="0.6">

        <TextView
            android:id="@+id/terminal_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#FF00FF00"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/terminal_shortcuts"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FF0D0D1A"
        android:paddingVertical="4dp"
        android:paddingHorizontal="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/terminal_scroll"
        app:layout_constraintRight_toLeftOf="@id/divider">

        <Button
            android:id="@+id/btn_clear"
            style="@style/TerminalShortcut"
            android:text="clear" />
        <Button
            android:id="@+id/btn_filter"
            style="@style/TerminalShortcut"
            android:text="filter" />
        <Button
            android:id="@+id/btn_share"
            style="@style/TerminalShortcut"
            android:text="share" />
        <Button
            android:id="@+id/btn_check"
            style="@style/TerminalShortcut"
            android:text="check" />
        <Button
            android:id="@+id/btn_download"
            style="@style/TerminalShortcut"
            android:text="download" />
        <Button
            android:id="@+id/btn_help"
            style="@style/TerminalShortcut"
            android:text="help" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#FF00FF00"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/terminal_shortcuts"
        app:layout_constraintRight_toLeftOf="@id/terminal_input" />

    <EditText
        android:id="@+id/terminal_input"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FF0D0D1A"
        android:fontFamily="monospace"
        android:textColor="#FF00FF00"
        android:textColorHint="#666666"
        android:hint="type command..."
        android:imeOptions="actionSend"
        android:inputType="text"
        android:padding="12dp"
        android:textSize="11sp"
        android:maxLines="10"
        android:gravity="top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/divider"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintWidth_percent="0.3" />

</androidx.constraintlayout.widget.ConstraintLayout>
